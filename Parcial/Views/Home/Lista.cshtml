
@{
    ViewBag.Title = "ListaP";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Lista de productos electronicos</h2>

<form action="/Home/AgregarProducto" method="post">

    <div class="fila">
        <div class="campo">
            <label>ID:</label>
            <input type="number" name="id" step="1" min="1" required />
        </div>

        <div class="campo">
            <label>Producto:</label>
            <input type="text" name="producto" required />
        </div>
    </div>

    <div class="fila">
        <div class="campo">
            <label>Categoria:</label>
            <select name="categoria" required>
                <option value="">Seleccione una categoria</option>
                <option>PGC (Productos de Gran Consumo)</option>
                <option>Electronica</option>
                <option>Bazar y Hogar</option>
                <option>Textil (Moda)</option>
                <option>Ocio y Cultura</option>
            </select>
        </div>

        <div class="campo">
            <label>Descripcion:</label>
            <input type="text" name="descripcion" required />
        </div>
    </div>

    <div class="campo">
        <label>Precio</label>
        <input type="number" name="precio" step="0.01" min="0" required />
    </div>

    <br><br>

    <button type="submit">Agregar</button>
</form>

<table border="1" cellpadding="5">
    <tr>
        <th>ID</th>
        <th>Producto</th>
        <th>Categoria</th>
        <th>Descripcion</th>
        <th>Precio</th>
        <th>Acción</th>
    </tr>

    @{
        int i = 0;
    }

    @foreach (var p in ViewBag.Productos)
    {
        <tr>
            <td>@p[0]</td>
            <td>@p[1]</td>
            <td>@p[2]</td>
            <td>@p[3]</td>
            <td>@p[4]</td>
            
            <td>
                <form action="/Home/EliminarProducto" method="post">
                    <input type="hidden" name="indice" value="@i" />
                    <button type="submit">Eliminar</button>
                </form>
            </td>


            <td>
                <form action="/Home/AgregarCarrito" method="post">
                    <input type="hidden" name="indice" value="@i" />
                    <button type="submit">Agregar al Carrito</button>
                </form>
            </td>
        </tr>

        i++;
    }

</table>